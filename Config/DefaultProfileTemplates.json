{
  "7_Days_to_Die": {
    "GameName": "7 Days to Die",
    "Prefix": "DZ",
    "LaunchArgs": "-logfile \"$LOGFILE\" -quit -batchmode -nographics -configfile=serverconfig.xml -dedicated",
    "StopMethod": "stdin",
    "SaveMethod": "stdin",
    "StdinStopCommand": "shutdown",
    "StdinSaveCommand": "saveworld",
    "SaveWaitSeconds": 10,
    "ProcessName": "7DaysToDieServer",
    "SteamAppId": 251570,
    "TelnetHost": "127.0.0.1",
    "TelnetPort": 8081,
    "MinRamGB": 4,
    "MaxRamGB": 12,
    "EnableAutoRestart": true,
    "RestartDelaySeconds": 10,
    "MaxRestartsPerHour": 5,
    "LogStrategy": "NewestFile",
    "ServerLogFile": "$LOGFILE",
    "ServerLogNote": "7 Days to Die writes the dedicated-server log to the path defined by -logfile. ECC also falls back to the newest dedicated-server log it can resolve from the install folder.",
    "Commands": {
      "players": {
        "Type": "Telnet",
        "Command": "listplayers"
      },
      "stop": {
        "Type": "Stop"
      },
      "restart": {
        "Type": "Restart"
      },
      "save": {
        "Type": "Telnet",
        "Command": "saveworld"
      },
      "status": {
        "Type": "Status"
      },
      "start": {
        "Type": "Start"
      },
      "version": {
        "Type": "Telnet",
        "Command": "version"
      }
    },
    "ExtraCommands": {
      "save": {
        "Type": "Telnet",
        "Command": "saveworld"
      },
      "players": {
        "Type": "Telnet",
        "Command": "listplayers"
      },
      "version": {
        "Type": "Telnet",
        "Command": "version"
      }
    }
  },
